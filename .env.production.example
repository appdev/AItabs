# ==========================================
# AItabs 生产环境配置
# 复制为 .env 并填写真实值后执行 docker compose up -d
# ==========================================

# JWT 签名密钥（必填，生产环境请用随机 32 位以上字符串）
# 生成示例：openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# 前端访问域名（用于后端 CORS 白名单）
# 例：https://tabs.yourdomain.com
FRONTEND_URL=http://localhost

# 前端对外暴露端口（默认 6600）
PORT=6600

# 数据目录路径（SQLite 数据库持久化目录）
# 默认使用 docker-compose.yml 同级目录下的 ./data 文件夹
# 可改为宿主机任意绝对路径，迁移时备份该目录即可
# 例：DATA_DIR=/opt/aitabs/data
DATA_DIR=./data
